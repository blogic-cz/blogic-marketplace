{
  "name": "blogic-marketplace",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "bun run check.ts",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint -c ./.oxlintrc.json --deny-warnings .",
    "lint:fix": "oxlint -c ./.oxlintrc.json --fix .",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@blogic-cz/oxc-config": "1.5.4",
    "@types/bun": "1.3.10",
    "@types/node": "25.3.3",
    "lefthook": "^2.1.2",
    "oxfmt": "0.36.0",
    "oxlint": "1.51.0",
    "typescript": "5.9.3"
  },
  "packageManager": "bun@1.3.10"
}
