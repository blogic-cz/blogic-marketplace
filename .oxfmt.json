{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "semi": true,
  "trailingComma": "es5",
  "singleQuote": false,
  "printWidth": 60,
  "tabWidth": 2,
  "useTabs": false,
  "bracketSpacing": true,
  "arrowParens": "always",
  "endOfLine": "lf",
  "bracketSameLine": false,
  "quoteProps": "as-needed",
  "sortImports": {
    "internalPattern": ["@/", "@blogic/"],
    "groups": [
      "type-import",
      ["value-builtin", "value-external"],
      "type-internal",
      "value-internal",
      ["type-parent", "type-sibling", "type-index"],
      ["value-parent", "value-sibling", "value-index"],
      "unknown"
    ]
  },
  "ignorePatterns": [
    "**/*.css",
    "**/*.eot",
    "**/*.gen.ts",
    "**/*.gif",
    "**/*.gz",
    "**/*.ico",
    "**/*.jpeg",
    "**/*.jpg",
    "**/*.json",
    "**/*.json5",
    "**/*.jsonc",
    "**/*.md",
    "**/*.pdf",
    "**/*.png",
    "**/*.sh",
    "**/*.svg",
    "**/*.tar",
    "**/*.ttf",
    "**/*.woff",
    "**/*.woff2",
    "**/*.yaml",
    "**/*.yml",
    "**/*.zip",
    "**/build",
    "**/coverage",
    "**/dist",
    "**/node_modules"
  ]
}
